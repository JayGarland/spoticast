{
  "rug-tool-whitelist": {
    "enabled": false,
    "_note": "DISABLED 2026-06-23: Antigravity CLI does not support invoke_subagent at runtime. The whitelist would block all tools while subagents are unavailable, paralyzing the agent. Re-enable when CLI subagent support is confirmed.",
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh",
            "args": ["-File", ".agents/plugins/rug-agentic-workflow/scripts/rug-pre-tool-use.ps1"],
            "timeout": 5
          }
        ]
      }
    ]
  },
  "rug-protocol-injection": {
    "PreInvocation": [
      {
        "type": "command",
        "command": "pwsh",
        "args": ["-File", ".agents/plugins/rug-agentic-workflow/scripts/rug-pre-invocation.ps1"],
        "timeout": 5
      }
    ]
  },
  "rug-stop-enforcement": {
    "Stop": [
      {
        "type": "command",
        "command": "pwsh",
        "args": ["-File", ".agents/plugins/rug-agentic-workflow/scripts/rug-stop.ps1"],
        "timeout": 5
      }
    ]
  }
}
