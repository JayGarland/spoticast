SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# ── Gemini (choose one auth method) ──────────────────────────────────────────

# Option A: Google AI Studio API key (easiest — no GCP setup required)
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Option B: Vertex AI via Application Default Credentials
# Run: gcloud auth application-default login
# If GEMINI_API_KEY is set, these are ignored.
# GOOGLE_CLOUD_PROJECT=your_gcp_project_id

# ── Last.fm (optional) ───────────────────────────────────────────────────────
# Enriches commentary with play counts, loved tracks, and listening history.
# Register at https://www.last.fm/api/account/create
# LASTFM_API_KEY=your_lastfm_api_key_here
# LASTFM_API_SECRET=your_lastfm_shared_secret_here

# ── Tuning ───────────────────────────────────────────────────────────────────
# GEMINI_MODEL=gemini-3.5-flash
# GEMINI_RESEARCH_MODEL=gemini-3.1-flash-lite          # was flash-lite-preview (shut down 2026-05-25)
# GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview        # was gemini-2.5-pro-preview-tts
MAX_TRACKS=30
# HOST=0.0.0.0          # uncomment for phone/Tailscale access (default: 127.0.0.1)
# PUBLIC_HOST=127.0.0.1  # public-facing hostname/IP for OAuth redirect (default: 127.0.0.1)
# PORT=8765
#
# ── Tailscale HTTPS (mobile) ─────────────────────────────────────────────────
# When accessed via Tailscale Serve, the server auto-detects the .ts.net host
# and uses HTTPS for the Spotify OAuth redirect URI.  No config changes needed.
# Just add the Tailscale URL to your Spotify Developer Dashboard:
#   https://<hostname>.<tailnet>.ts.net:<port>/auth/callback
# Example: https://buttking.tail15ea24.ts.net:8765/auth/callback
